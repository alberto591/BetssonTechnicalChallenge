{
  "compilerOptions": {
    "outDir": "./dist",
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["node", "@wdio/globals/types", "expect-webdriverio"]
  },
  "include": ["src/**/*.ts", "config/**/*.ts"],
  "exclude": ["node_modules"]
}
